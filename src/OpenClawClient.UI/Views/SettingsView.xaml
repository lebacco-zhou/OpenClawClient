<Window x:Class="OpenClawClient.UI.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="设置 - OpenClaw Client" 
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="OpenClaw Client 设置" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"
                   HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 基本设置 -->
                <GroupBox Header="基本设置" Margin="0,0,0,20">
                    <StackPanel Margin="10">
                        <!-- 文件下载路径 -->
                        <TextBlock Text="文件下载路径" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DownloadPathTextBox" 
                                     Grid.Column="0" 
                                     Margin="0,0,10,0"
                                     materialDesign:HintAssist.Hint="选择文件下载路径"/>
                            <Button x:Name="BrowsePathButton"
                                    Grid.Column="1"
                                    Content="浏览"
                                    Click="BrowsePathButton_Click"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </Grid>

                        <!-- 自动创建月度子文件夹 -->
                        <CheckBox x:Name="AutoSubfolderByMonthCheckBox"
                                  Content="自动创建月度子文件夹（按 YYYY-MM 格式）"
                                  Margin="0,0,0,15"
                                  IsChecked="True"/>

                        <!-- 记住登录信息 -->
                        <CheckBox x:Name="RememberLoginCheckBox"
                                  Content="记住登录信息（保存 Token）"
                                  Margin="0,0,0,15"/>
                    </StackPanel>
                </GroupBox>

                <!-- 高级设置 -->
                <GroupBox Header="高级设置" Margin="0,0,0,20">
                    <StackPanel Margin="10">
                        <!-- 服务器地址 -->
                        <TextBlock Text="服务器地址" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="ServerUrlTextBox" 
                                 Margin="0,0,0,15"
                                 materialDesign:HintAssist.Hint="服务器地址，如: https://www.lebacco.cn:8443"/>

                        <!-- 自动重连间隔 -->
                        <TextBlock Text="自动重连间隔（秒）" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="ReconnectIntervalTextBox" 
                                 Margin="0,0,0,15"
                                 Text="10"
                                 materialDesign:HintAssist.Hint="重连间隔时间（秒）"
                                 TextAlignment="Center" 
                                 Width="100"/>

                        <!-- 消息历史记录数量 -->
                        <TextBlock Text="消息历史记录数量" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="MessageHistoryCountTextBox" 
                                 Margin="0,0,0,15"
                                 Text="50"
                                 materialDesign:HintAssist.Hint="保留的历史消息数量"
                                 TextAlignment="Center" 
                                 Width="100"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button x:Name="SaveButton"
                    Content="保存"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="SaveButton_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
            <Button x:Name="CancelButton"
                    Content="取消"
                    Width="80"
                    Click="CancelButton_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
        </StackPanel>
    </Grid>
</Window>