<Window x:Class="OpenClawClient.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="OpenClaw Client - 登录" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo and Title -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
            <materialDesign:PackIcon Kind="Robot" Width="60" Height="60" 
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="OpenClaw Client" 
                      FontSize="24" 
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Margin="0,10,0,5"/>
            <TextBlock Text="安全加密聊天客户端" 
                      FontSize="12"
                      Foreground="{DynamicResource MaterialDesignBodyLight}"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            
            <!-- Server URL -->
            <TextBox x:Name="ServerUrlTextBox"
                    materialDesign:HintAssist.Hint="服务器地址"
                    materialDesign:HintAssist.HelperText="例如：https://www.lebacco.cn:8443"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Margin="0,0,0,20"
                    Text="https://www.lebacco.cn:8443"/>

            <!-- Gateway Token -->
            <PasswordBox x:Name="TokenPasswordBox"
                        materialDesign:HintAssist.Hint="Gateway Token"
                        materialDesign:HintAssist.HelperText="输入 Gateway Token"
                        Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                        Margin="0,0,0,30"
                        materialDesign:PasswordBoxAssist.Password="{x:Null}"/>

            <!-- Login and Settings Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Button x:Name="LoginButton"
                       Content="登 录"
                       Style="{StaticResource MaterialDesignRaisedButton}"
                       Height="45"
                       Width="120"
                       FontSize="16"
                       Click="LoginButton_Click"
                       materialDesign:ButtonAssist.CornerRadius="8"/>
                
                <Button x:Name="SettingsButton"
                       Content="设 置"
                       Style="{StaticResource MaterialDesignRaisedLightButton}"
                       Height="45"
                       Width="120"
                       FontSize="16"
                       Click="SettingsButton_Click"
                       materialDesign:ButtonAssist.CornerRadius="8"/>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock x:Name="ErrorTextBlock"
                      Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                      FontSize="12"
                      Margin="0,15,0,0"
                      TextWrapping="Wrap"
                      Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
