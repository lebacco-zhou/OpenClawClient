<Window x:Class="OpenClawClient.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="OpenClaw Client - 登录" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo and Title -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
            <materialDesign:PackIcon Kind="Robot" Width="60" Height="60" 
                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
            <TextBlock Text="OpenClaw Client" 
                      FontSize="24" 
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Margin="0,10,0,5"/>
            <TextBlock Text="安全加密聊天客户端" 
                      FontSize="12"
                      Foreground="{DynamicResource MaterialDesignBodyLight}"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Login Form -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            
            <!-- Server URL -->
            <TextBox x:Name="ServerUrlTextBox"
                    materialDesign:HintAssist.Hint="服务器地址"
                    materialDesign:HintAssist.HelperText="例如：https://www.lebacco.cn:8443"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Margin="0,0,0,20"
                    Text="https://www.lebacco.cn:8443"/>

            <!-- Gateway Token -->
            <PasswordBox x:Name="TokenPasswordBox"
                        materialDesign:HintAssist.Hint="Gateway Token"
                        materialDesign:HintAssist.HelperText="31 位十六进制令牌"
                        Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                        Margin="0,0,0,20"
                        materialDesign:PasswordBoxAssist.Password="{x:Null}"/>

            <!-- Download Path -->
            <DockPanel Margin="0,0,0,20">
                <Button x:Name="BrowseButton"
                       Content="浏览"
                       DockPanel.Dock="Right"
                       Width="60"
                       Margin="10,0,0,0"
                       Click="BrowseButton_Click"/>
                <TextBox x:Name="DownloadPathTextBox"
                        materialDesign:HintAssist.Hint="文件下载路径"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        IsReadOnly="True"/>
            </DockPanel>

            <!-- Options -->
            <StackPanel Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="RememberLoginCheckBox"
                             Content="记住登录"
                             IsChecked="True"
                             Margin="0,0,20,0"/>
                    <CheckBox x:Name="AutoSubfolderCheckBox"
                             Content="自动创建日期子文件夹"
                             IsChecked="True"/>
                </StackPanel>
                
                <!-- Model Selection -->
                <Label Content="AI 模型选择：" FontSize="12" Margin="0,0,0,5"/>
                <ComboBox x:Name="ModelComboBox"
                         materialDesign:HintAssist.Hint="选择 AI 模型"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         SelectedIndex="0"
                         Margin="0,0,0,10">
                    <ComboBoxItem Content="Qwen 3.5 Plus"/>
                    <ComboBoxItem Content="Qwen 3 Coder Plus"/>
                    <ComboBoxItem Content="Qwen 3 Coder Max"/>
                    <ComboBoxItem Content="Qwen 3 Max"/>
                    <ComboBoxItem Content="Qwen 2.5"/>
                    <ComboBoxItem Content="Custom Model"/>
                </ComboBox>
            </StackPanel>

            <!-- Error Message -->
            <TextBlock x:Name="ErrorTextBlock"
                      Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                      FontSize="12"
                      Margin="0,0,0,10"
                      TextWrapping="Wrap"
                      Visibility="Collapsed"/>
        </StackPanel>

        <!-- Login Button -->
        <Button x:Name="LoginButton"
               Grid.Row="2"
               Content="登 录"
               Style="{StaticResource MaterialDesignRaisedButton}"
               Height="45"
               FontSize="16"
               Click="LoginButton_Click"
               materialDesign:ButtonAssist.CornerRadius="8"/>
    </Grid>
</Window>
