<Window x:Class="OpenClawClient.UI.Views.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="图片查看器" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <!-- 图片显示区域 -->
        <Border x:Name="ImageBorder"
                Background="Transparent"
                MouseWheel="ImageBorder_MouseWheel"
                MouseLeftButtonDown="ImageBorder_MouseLeftButtonDown"
                MouseMove="ImageBorder_MouseMove"
                MouseLeftButtonUp="ImageBorder_MouseLeftButtonUp">
            <Image x:Name="MainImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- 工具栏 -->
        <Border VerticalAlignment="Top"
                Background="#CC000000"
                Padding="10,5"
                Visibility="{Binding ElementName=ToolbarGrid, Path=Visibility}">
            <Grid x:Name="ToolbarGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="ZoomText"
                          Text="100%"
                          Foreground="White"
                          VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔍-" Click="ZoomOut_Click"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           ToolTip="缩小 (Ctrl+-)"/>
                    <Button Content="🔍+" Click="ZoomIn_Click"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           ToolTip="放大 (Ctrl++)"/>
                    <Button Content="🔄" Click="ResetZoom_Click"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           ToolTip="重置 (Ctrl+0)"/>
                    <Button Content="💾" Click="Save_Click"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           ToolTip="保存 (Ctrl+S)"/>
                    <Button Content="✕" Click="Close_Click"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="White"
                           ToolTip="关闭 (Esc)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 文件名提示 -->
        <Border VerticalAlignment="Bottom"
                Background="#CC000000"
                Padding="10,5"
                Visibility="{Binding ElementName=ToolbarGrid, Path=Visibility}">
            <TextBlock x:Name="FileNameText"
                      Foreground="White"
                      FontSize="12"/>
        </Border>
    </Grid>
</Window>
