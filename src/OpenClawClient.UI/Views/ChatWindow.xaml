<Window x:Class="OpenClawClient.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="OpenClaw Client - 连接中..." 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection Status Bar -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryHueMidBrush}" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="ConnectionStatusText"
                          Text="● 已连接"
                          Foreground="White"
                          FontWeight="SemiBold"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="🔒 端到端加密" Foreground="White" Opacity="0.8" Margin="0,0,15,0"/>
                    <TextBlock x:Name="ServerUrlText" Foreground="White" Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages List -->
        <ListBox x:Name="MessagesListBox"
                Grid.Row="1"
                BorderThickness="0"
                Background="Transparent"
                Padding="10"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                AllowDrop="True"
                Drop="MessagesListBox_Drop"
                PreviewDragOver="MessagesListBox_PreviewDragOver">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5,3" Padding="12,8" CornerRadius="12"
                            Background="{Binding Role, Converter={StaticResource RoleToBackgroundConverter}}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            MaxWidth="600"
                            HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlignmentConverter}}">
                        <StackPanel>
                            <!-- File/Image Preview -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource FileTypeToVisibilityConverter}}">
                                <Image Source="{Binding FilePath}" 
                                       MaxHeight="200" MaxWidth="400"
                                       Stretch="Uniform"
                                       Margin="0,0,0,5"
                                       Cursor="Hand"
                                       MouseLeftButtonUp="Image_MouseLeftButtonUp"/>
                                <TextBlock Text="{Binding FileName}" 
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,5"/>
                            </StackPanel>
                            
                            <!-- Message Content -->
                            <TextBlock Text="{Binding Content}" 
                                      TextWrapping="Wrap"
                                      FontSize="14"/>
                            
                            <!-- Timestamp and Status -->
                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Right"
                                       Margin="0,5,0,0">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                          FontSize="10"
                                          Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                <TextBlock Text=" 🔒" 
                                          Visibility="{Binding IsEncrypted, Converter={StaticResource BoolToVisibilityConverter}}"
                                          FontSize="10"/>
                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                          FontSize="10"
                                          Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area -->
        <Border Grid.Row="2" 
                Background="{DynamicResource MaterialDesignPaper}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Attach Button -->
                <Button x:Name="AttachButton"
                       Content="📎"
                       Width="40" Height="40"
                       ToolTip="附加文件"
                       Click="AttachButton_Click"
                       Style="{StaticResource MaterialDesignFlatButton}"/>
                
                <!-- Input TextBox -->
                <TextBox x:Name="InputTextBox"
                        Grid.Column="1"
                        materialDesign:HintAssist.Hint="输入消息... (Ctrl+V 粘贴图片/文件，Ctrl+Enter 发送)"
                        materialDesign:HintAssist.HelperText=""
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        MaxHeight="150"
                        KeyDown="InputTextBox_KeyDown"
                        Margin="5,0"/>
                
                <!-- Send Button -->
                <Button x:Name="SendButton"
                       Grid.Column="2"
                       Content="发送"
                       Width="80"
                       VerticalAlignment="Bottom"
                       Click="SendButton_Click"
                       Style="{StaticResource MaterialDesignRaisedButton}"
                       materialDesign:ButtonAssist.CornerRadius="8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
