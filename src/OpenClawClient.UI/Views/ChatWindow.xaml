<Window x:Class="OpenClawClient.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="OpenClaw Client - 连接中..." 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Model Selection Bar -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" Padding="10,8" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="🤖 AI 模型:" 
                          Foreground="{StaticResource TextPrimaryBrush}"
                          VerticalAlignment="Center"
                          FontWeight="SemiBold"
                          Margin="0,0,10,0"/>
                
                <ComboBox x:Name="ModelComboBox"
                         Grid.Column="1"
                         materialDesign:HintAssist.Hint="选择 AI 模型"
                         Style="{StaticResource MaterialDesignOutlinedComboBox}"
                         SelectedIndex="0"
                         SelectionChanged="ModelComboBox_SelectionChanged"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="Transparent"
                         BorderBrush="#3A3A3A">
                    <ComboBoxItem Content="Qwen 3.5 Plus"/>
                    <ComboBoxItem Content="Qwen 3 Coder Plus"/>
                    <ComboBoxItem Content="Qwen 3 Coder Max"/>
                    <ComboBoxItem Content="Qwen 3 Max"/>
                    <ComboBoxItem Content="Qwen 2.5"/>
                    <ComboBoxItem Content="Custom Model"/>
                </ComboBox>
                
                <Button Grid.Column="2" 
                       Content="🔍"
                       Style="{StaticResource CircleButtonStyle}"
                       ToolTip="搜索消息"
                       Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <!-- Connection Status Bar -->
        <Border Grid.Row="1" Background="{StaticResource PrimaryBrush}" Padding="10,5" CornerRadius="8" Margin="0,4,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="ConnectionStatusText"
                          Text="🟢 已连接"
                          Foreground="White"
                          FontWeight="SemiBold"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="🔒 端到端加密" Foreground="White" Opacity="0.8" Margin="0,0,15,0"/>
                    <TextBlock x:Name="ServerUrlText" Foreground="White" Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages List -->
        <ListBox x:Name="MessagesListBox"
                Grid.Row="2"
                BorderThickness="0"
                Background="{StaticResource BackgroundBrush}"
                Padding="16"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarWidth="8"
                AllowDrop="True"
                Drop="MessagesListBox_Drop"
                PreviewDragOver="MessagesListBox_PreviewDragOver">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="MessageBorder" 
                            Margin="0,8"
                            MaxWidth="600">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                        <Setter Property="Style" Value="{StaticResource UserMessageStyle}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                        <Setter Property="Style" Value="{StaticResource AssistantMessageStyle}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Role}" Value="System">
                                        <Setter Property="Style" Value="{StaticResource SystemMessageStyle}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <!-- File/Image Preview -->
                            <StackPanel Visibility="{Binding Type, Converter={StaticResource MessageTypeToVisibilityConverter}}">
                                <Image Source="{Binding FilePath}" 
                                       MaxHeight="200" MaxWidth="400"
                                       Stretch="Uniform"
                                       Margin="0,0,0,8"
                                       Cursor="Hand"
                                       MouseLeftButtonUp="Image_MouseLeftButtonUp"
                                       Visibility="{Binding Type, Converter={StaticResource ImageTypeToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding FileName}" 
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,5"/>
                            </StackPanel>
                            
                            <!-- Message Content -->
                            <TextBlock x:Name="ContentText" 
                                      Text="{Binding Content}" 
                                      TextWrapping="Wrap"
                                      FontSize="14"
                                      LineHeight="20"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="User">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="System">
                                                <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                                                <Setter Property="FontStyle" Value="Italic"/>
                                                <Setter Property="FontSize" Value="12"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <!-- Timestamp and Status -->
                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Right"
                                       Margin="0,8,0,0">
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                          FontSize="10"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          Opacity="0.8"/>
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C14.21,7 16,8.79 16,11C16,13.21 14.21,15 12,15C9.79,15 8,13.21 8,11C8,8.79 9.79,7 12,7Z"
                                      Fill="{StaticResource SuccessBrush}" 
                                      Width="12" Height="12"
                                      Margin="6,0,0,0"
                                      Visibility="{Binding IsEncrypted, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area -->
        <Border Grid.Row="3" 
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="#3A3A3A"
                BorderThickness="1"
                CornerRadius="24"
                Padding="12"
                Margin="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Attachment Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="AttachButton"
                           Content="📎"
                           Style="{StaticResource CircleButtonStyle}"
                           ToolTip="附加文件"
                           Click="AttachButton_Click"/>
                    <Button Content="📷"
                           Style="{StaticResource CircleButtonStyle}"
                           ToolTip="拍照/选择图片"/>
                    <Button Content="🎵"
                           Style="{StaticResource CircleButtonStyle}"
                           ToolTip="语音消息"/>
                </StackPanel>
                
                <!-- Input TextBox -->
                <TextBox x:Name="InputTextBox"
                        Grid.Column="1"
                        Style="{StaticResource ModernTextBoxStyle}"
                        materialDesign:HintAssist.Hint="输入消息... (Ctrl+V 粘贴图片/文件，Ctrl+Enter 发送)"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        MaxHeight="120"
                        KeyDown="InputTextBox_KeyDown"
                        Margin="8,0"/>
                
                <!-- Send Button -->
                <Button x:Name="SendButton"
                       Grid.Column="2"
                       Content="发送"
                       Style="{StaticResource SendButtonStyle}"
                       Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
